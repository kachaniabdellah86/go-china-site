generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Application {
  id           String   @id @default(cuid())
  fullName     String
  phone        String
  whatsapp     String?
  email        String?
  city         String
  address      String?
  studyLevel   String
  fieldOfStudy String?
  objective    String
  message      String?
  status       String   @default("NEW")
  createdAt    DateTime @default(now())
}